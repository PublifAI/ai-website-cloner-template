# Directory where client data is stored (discovery, assets, reports, output).
# Default: ../clients (parent-level clients folder, shared across all Publifai tools)
# Use absolute path or relative to this repo's root.
CLIENTS_DIR=../clients

# Google PageSpeed Insights API key (free — 25k queries/day per key)
# Create at: https://console.cloud.google.com/apis/credentials
# Enable PSI API: https://console.cloud.google.com/apis/library/pagespeedonline.googleapis.com
PSI_API_KEY=
